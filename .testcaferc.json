{
  "browsers": {
    "path": "chromium",
    "cmd": "--window-size=1280,720 --incognito"
  },
  "src": [
    "packages/media-module/tests/**/*.ts"
  ],
  "appCommand": "yarn dev:test",
  "appInitDelay": 2000,
  "screenshots": {
    "takeOnFails": true
  },
  "stopOnFirstFail": true,
  "hostname": "localhost",
  "baseUrl": "http://localhost:8000",
  "retryTestPages": true,
  "pageLoadTimeout": 10000,
  "pageRequestTimeout": 60000,
  "skipJsErrors": true
}
